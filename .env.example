# ── Application ───────────────────────────────────────────────────────
APP_NAME="AI Combination Server"
APP_VERSION="0.1.0"
DEBUG=false

# ── Server ────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database (AWS RDS PostgreSQL) ───────────────────────────────────
# Option A — AWS Secrets Manager (recommended for production)
#   Store a JSON secret in Secrets Manager with keys:
#   {"username","password","host","port","dbname"}
#   DATABASE_URL is ignored when AWS_SECRET_NAME is set.
DATABASE_URL=postgresql://localhost:5432/ai_sources
AWS_SECRET_NAME=prod
AWS_REGION=us-east-1
RDS_IAM_AUTH=false
#
# Option B — RDS IAM token auth (no password in URL, no Secrets Manager)
# DATABASE_URL=postgresql://postgres@<host>:5432/postgres
# RDS_IAM_AUTH=true
# AWS_REGION=us-east-1
# AWS_SECRET_NAME=
#   Requires: GRANT rds_iam TO <user>;  and rds-db:connect IAM permission.
#
# Option C — Static password (local Docker or plain PostgreSQL)
# DATABASE_URL=postgresql://aiuser:aipassword@localhost:5433/ai_sources
# RDS_IAM_AUTH=false
# AWS_SECRET_NAME=

# ── LLM Provider ──────────────────────────────────────────────────────
LLM_PROVIDER=openai          # openai | anthropic | gemini
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=AI...
GEMINI_MODEL=gemini-1.5-flash

# ── Local Models ──────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1

# ── Retrieval ─────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=10
RERANK_TOP_K=3
RELEVANCE_THRESHOLD=-10.0

# ── Token / Cost ──────────────────────────────────────────────────────
MAX_CONTEXT_TOKENS=1500
MAX_OUTPUT_TOKENS=512

# ── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
