# --- Application ---
APP_NAME="Personal AI Representative"
APP_VERSION="0.2.0"
DEBUG=false

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Persona ---
PERSONA_NAME="Patrick Tran"
PERSONA_ALIASES="Phuc, Nguyen, Bin"

# --- Database ---
# Local Docker example:
DATABASE_URL=postgresql://aiuser:aipassword@localhost:5433/ai_sources
AWS_SECRET_NAME=
AWS_REGION=us-east-1
RDS_IAM_AUTH=false

# --- LLM Provider ---
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Local Models ---
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1

# --- Retrieval ---
RETRIEVAL_TOP_K=10
RERANK_TOP_K=3
RELEVANCE_THRESHOLD=0.35
RELEVANCE_GATE_ENABLED=true

# --- Prompt Cost Controls ---
MAX_CONTEXT_TOKENS=1800
MAX_OUTPUT_TOKENS=450
MAX_USER_QUERY_CHARS=1200
MAX_HISTORY_MESSAGES=6
MAX_HISTORY_CHARS=900
MAX_EVIDENCE_CHUNKS=4
MAX_EVIDENCE_CHARS=1600
MAX_EVIDENCE_CHUNK_CHARS=420
GENERATION_TEMPERATURE=0.2

# --- Speech / Voice Output ---
SPEECH_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_VOICE_ID=
OPENAI_TTS_INSTRUCTIONS="Speak English slowly and clearly with a natural Vietnamese accent, like a Vietnamese speaker speaking English. Keep it warm, calm, and easy to understand."
OPENAI_TTS_RESPONSE_FORMAT=mp3
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_STABILITY=0.4
ELEVENLABS_SIMILARITY_BOOST=0.85
ELEVENLABS_STYLE=0.0
ELEVENLABS_USE_SPEAKER_BOOST=true
LOCAL_TTS_URL=http://127.0.0.1:7861/v1/voice/synthesize
LOCAL_TTS_API_KEY=
LOCAL_TTS_REFERENCE_AUDIO_PATH=
LOCAL_TTS_REFERENCE_TEXT=
LOCAL_TTS_MODEL=
LOCAL_TTS_TIMEOUT_SECONDS=300
SPEECH_DEFAULT_SPEED=0.7
SPEECH_DEFAULT_INSTRUCTIONS="Speak English slowly and clearly with a natural Vietnamese accent, like a Vietnamese speaker speaking English. Keep it warm, calm, and easy to understand."
SPEECH_PUNCTUATION_PAUSES_ENABLED=true
SPEECH_CHUNK_SIZE=4096
MAX_SPEECH_INPUT_CHARS=4096
TRANSCRIPTION_PROVIDER=openai
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_STT_PROMPT="Names that may appear: Patrick Tran, Phuc, Nguyen, Bin."
MAX_SPEECH_UPLOAD_BYTES=26214400

# --- Chat sessions ---
SESSION_MAX_TURNS=4

# --- Rate limiting ---
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
