# --- Application ---
APP_NAME="Personal AI Representative"
APP_VERSION="0.2.0"
DEBUG=false

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Persona ---
PERSONA_NAME="Patrick Tran"
PERSONA_ALIASES="Phuc, Nguyen, Bin"

# --- Database ---
# Local Docker example:
DATABASE_URL=postgresql://aiuser:aipassword@localhost:5433/ai_sources
AWS_SECRET_NAME=
AWS_REGION=us-east-1
RDS_IAM_AUTH=false

# --- LLM Provider ---
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Local Models ---
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1

# --- Retrieval ---
RETRIEVAL_TOP_K=10
RERANK_TOP_K=3
RELEVANCE_THRESHOLD=0.35
RELEVANCE_GATE_ENABLED=true

# --- Prompt Cost Controls ---
MAX_CONTEXT_TOKENS=1800
MAX_OUTPUT_TOKENS=450
MAX_USER_QUERY_CHARS=1200
MAX_HISTORY_MESSAGES=6
MAX_HISTORY_CHARS=900
MAX_EVIDENCE_CHUNKS=4
MAX_EVIDENCE_CHARS=1600
MAX_EVIDENCE_CHUNK_CHARS=420
GENERATION_TEMPERATURE=0.2

# --- Chat sessions ---
SESSION_MAX_TURNS=4

# --- Rate limiting ---
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
